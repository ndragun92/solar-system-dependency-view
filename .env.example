# GitHub integration (server-side only)
# If these are missing, the API route falls back to mocked data.
GITHUB_TOKEN=
GITHUB_OWNER=
# Comma-separated list of repositories, for example: repo-a,repo-b,repo-c
GITHUB_REPOS=
# Optional override
GITHUB_API_BASE=https://api.github.com

# Public runtime config used by page-level useFetch
# Usually keep default
NUXT_PUBLIC_SOLAR_DATA_ENDPOINT=/api/solar-system